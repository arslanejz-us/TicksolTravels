generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Business models
model Booking {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  service       String
  packageType   String
  destination   String
  date          DateTime
  travelers     Int      @default(1)
  status        String   @default("pending")
  totalPrice    String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  serviceType String?
  message     String   @db.Text
  isRead      Boolean  @default(false)
  reply       String?  @db.Text
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
}

model Service {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  icon        String?
  rating      Int     @default(3)
  price3Star  String?
  price4Star  String?
  pricePremium String?
  isActive    Boolean @default(true)
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Destination {
  id          String  @id @default(cuid())
  name        String
  country     String
  description String  @db.Text
  image       String?
  packages    Package[]
  isActive    Boolean @default(true)
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  type          String      // family, corporate, vip, custom
  price         String
  duration      String
  highlights    String[]
  destination   Destination? @relation(fields: [destinationId], references: [id])
  destinationId String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
